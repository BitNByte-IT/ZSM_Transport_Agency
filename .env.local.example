# ===== SMTP (Free Gmail setup) =====
# 1. Turn on 2-Step Verification on your Google account
# 2. Go to: Google Account > Security > App passwords
# 3. Generate an app password for "Mail" and paste it below as SMTP_PASS
# 4. Copy this file to ".env.local" and fill in real values

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=zsmtransportagency@gmail.com
SMTP_PASS=your_16_char_app_password_here
MAIL_TO=zsmtransportagency@gmail.com
