# ===== External Email Service =====
# URL of the deployed ZSM Email Service (Railway or Render)
EMAIL_SERVICE_URL=https://your-email-service.railway.app

# Must match API_SECRET in the email service's env vars
EMAIL_SERVICE_SECRET=your_strong_random_secret_here

# Where contact form emails are delivered (controls the recipient from Vercel side)
MAIL_TO=zsmtransportagency@gmail.com
